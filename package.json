{
  "name": "@gofore/gds",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node -e \"const fs=require('fs'); fs.copyFileSync('dist/index.html','dist/404.html'); fs.writeFileSync('dist/.nojekyll','');\"",
    "deploy": "npm run build && npx gh-pages -d dist -t true",
    "build:lib": "npm run generate:icons && tsup",
    "generate:icons": "node scripts/generate-icon-map.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync-figma-tokens": "node scripts/sync-figma-tokens.js"
  },
  "dependencies": {
    "@chakra-ui/react": ">=3.0.0",
    "@emotion/react": ">=11.0.0",
    "next-themes": ">=0.4.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-icons": ">=5.0.0"
  },
  "peerDependencies": {
    "@chakra-ui/react": ">=3.0.0",
    "@emotion/react": ">=11.0.0",
    "next-themes": ">=0.4.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-icons": ">=5.0.0"
  },
  "devDependencies": {
    "gh-pages": "^4.0.0",
    "react-router-dom": "^7.13.1",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
